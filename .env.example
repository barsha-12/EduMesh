# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://edumesh:password@localhost:5432/edumesh
REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://localhost:27017/edumesh

# ─── Auth ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_random_64_char_string_for_access_tokens_security
JWT_REFRESH_SECRET=change_me_to_a_random_64_char_string_for_refresh_tokens_security
BCRYPT_ROUNDS=12

# ─── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-...
DEEPL_API_KEY=your_deepl_api_key_here
QDRANT_URL=http://localhost:6333

# ─── Storage ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Blockchain ───────────────────────────────────────
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here
