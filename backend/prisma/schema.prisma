generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  STUDENT
  MENTOR
  ADMIN
  NGO
}

enum ContentType {
  VIDEO
  ARTICLE
  QUIZ
  EXERCISE
  PODCAST
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  profile      Profile?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  avatarUrl   String?
  language    String    @default("en")
  gradeLevel  Int?
  location    Json?     // { lat, lng, country, region }
  isOnline    Boolean   @default(false)
  lastSeen    DateTime?

  @@index([language])
  @@index([isOnline])
}

model LearnerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  knowledgeMap  Json     // { subject: { topic: masteryScore 0-1 } }
  learningStyle String   @default("visual") // visual | auditory | kinesthetic | reading
  pace          Float    @default(1.0)      // multiplier: 0.5 slow, 1.0 normal, 2.0 fast
  preferredLang String   @default("en")
  weeklyGoalMins Int     @default(60)
  streakDays    Int      @default(0)
  totalMinutes  Int      @default(0)
  lastUpdated   DateTime @default(now())

  @@index([userId])
}

model Content {
  id           String           @id @default(cuid())
  title        String
  body         String           @db.Text
  type         ContentType
  subject      String
  topic        String
  gradeLevel   Int
  language     String
  durationMins Int
  offlineBlob  String?          // base64 or CDN URL for offline caching
  tags         String[]
  sourceUrl    String?
  createdAt    DateTime         @default(now())
  sessions     LearningSession[]

  @@index([subject, topic])
  @@index([gradeLevel])
  @@index([language])
  @@index([type])
}

model LearningSession {
  id            String    @id @default(cuid())
  studentId     String
  contentId     String
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationSecs  Int       @default(0)
  completionPct Float     @default(0)
  quizScore     Float?
  aiNotes       Json?     // AI-generated observations about this session
  wasOffline    Boolean   @default(false)

  @@index([studentId])
  @@index([contentId])
  @@index([startedAt])
}

model MentorMatch {
  id          String      @id @default(cuid())
  studentId   String
  mentorId    String
  subject     String
  status      MatchStatus @default(PENDING)
  scheduledAt DateTime?
  sessionLog  Json[]
  createdAt   DateTime    @default(now())

  @@index([studentId])
  @@index([mentorId])
  @@index([status])
}

model Credential {
  id           String   @id @default(cuid())
  studentId    String
  subject      String
  level        String
  issuedAt     DateTime @default(now())
  txHash       String?  // Polygon transaction hash
  ipfsCid      String?  // IPFS content ID
  metadataJson Json     // W3C Verifiable Credential format

  @@index([studentId])
}

model SyncQueue {
  id        String     @id @default(cuid())
  deviceId  String
  userId    String
  payload   Json
  syncedAt  DateTime?
  status    SyncStatus @default(PENDING)
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([status])
}
