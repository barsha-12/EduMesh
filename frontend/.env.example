# EduMesh Elite - Environment Template
# Copy this to .env and fill in your real production keys.

# --- MONGODB ---
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/edumesh_v2
MONGODB_URI=your_mongodb_uri_here

# --- REDIS (UPSTASH) ---
# Used for rate limiting
REDIS_URL=your_redis_url_here

# --- AI API KEYS ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- AUTHENTICATION (JWT) ---
# 32+ character random string
NEXTAUTH_SECRET=your_nextauth_secret_here

# --- SUPABASE ---
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- GOOGLE OAUTH (FALLBACK/LEGACY) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- DEPLOYMENT ---
VITE_FRONTEND_URL=https://edu-mesh.vercel.app
